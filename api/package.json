{
  "name": "portugal-strikes-scraper",
  "version": "1.0.0",
  "description": "Scraper service for Portuguese strikes",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "tsx src/index.ts",
    "scrape": "tsx src/index.ts --run-once",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "express": "^5.1.0",
    "mongoose": "^8.0.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^22.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "dotenv": "^16.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
